@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="flex h-screen bg-slate-50 font-sans overflow-hidden selection:bg-indigo-500/30 relative">

    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-indigo-400/20 rounded-full mix-blend-multiply filter blur-[120px] pointer-events-none"></div>

    <aside class="w-[280px] bg-[#09090b] text-white flex flex-col hidden md:flex z-20 relative border-r border-slate-800">
        <div class="absolute top-[-10%] left-[-10%] w-[300px] h-[300px] bg-indigo-600/30 rounded-full mix-blend-screen filter blur-[80px] pointer-events-none"></div>
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20 mix-blend-overlay pointer-events-none"></div>
        <div class="h-24 flex items-center px-8 border-b border-white/10 relative z-10"><div class="h-10 w-10 bg-gradient-to-br from-blue-600 via-indigo-600 to-violet-600 rounded-xl flex items-center justify-center mr-3 shadow-lg ring-2 ring-white/20"><i class="material-icons text-white text-[20px]">holiday_village</i></div><span class="text-xl font-black tracking-widest uppercase">B-SERVE</span></div>
        <div class="px-6 py-8 relative z-10">
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 pl-1">Administration</p>
            <nav class="space-y-2">
                <a href="#" ng-click="goTo('HomeDashboard')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">dashboard</i> Dashboard</a>
                <a href="#" class="flex items-center px-4 py-3 bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 text-white rounded-2xl font-bold transition-all shadow-lg shadow-indigo-500/25"><i class="material-icons mr-3 text-white text-[20px]">how_to_reg</i> Approvals</a>
                <a href="#" ng-click="goTo('AdminUsers')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">people</i> Directory</a>
                <a href="#" ng-click="goTo('AdminRequest')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">assignment</i> Requests</a>
            </nav>
        </div>
        <div class="mt-auto p-6 relative z-10 border-t border-white/10"><button ng-click="goTo('LogIn')" class="flex items-center justify-center w-full px-4 py-3 bg-white/5 text-slate-300 hover:text-white hover:bg-rose-500/80 rounded-2xl font-bold transition-all"><i class="material-icons mr-2 text-[20px]">logout</i> Sign Out</button></div>
    </aside>

    <main class="flex-1 flex flex-col relative animate-slide-up overflow-y-auto z-10">
        <header class="h-24 bg-white/60 backdrop-blur-2xl border-b border-white sticky top-0 z-30 flex items-center px-10 shadow-[0_4px_30px_rgb(0,0,0,0.03)]">
            <div><h1 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-slate-900 to-slate-700 tracking-tight">Pending Approvals</h1><p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-1">Review resident applications</p></div>
        </header>

        <div class="p-10 flex-1 flex flex-col max-w-7xl mx-auto w-full">
            <div class="bg-white/70 backdrop-blur-2xl rounded-[2.5rem] border border-white shadow-[0_8px_40px_rgb(0,0,0,0.06)] overflow-hidden mb-8">
                <div class="overflow-x-auto">
                    <table class="min-w-full text-left">
                        <thead class="bg-white/50 border-b border-slate-100">
                            <tr>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Resident Identity</th>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Contact & Address</th>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Requested Credentials</th>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100/50">
                            <tr ng-repeat="user in userArray | filter:{Role:'Resident', Status:'Pending'} track by $index" class="hover:bg-white/50 transition-colors">
                                <td class="px-8 py-6">
                                    <div class="flex items-center">
                                        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-indigo-100 to-violet-100 text-indigo-700 flex items-center justify-center font-black text-lg mr-4 border border-indigo-200 shadow-sm">{{user.FirstName.charAt(0)}}</div>
                                        <div><div class="font-black text-slate-900 text-sm">{{user.FirstName}} {{user.MiddleName}} {{user.LastName}}</div><span class="px-2.5 py-1 inline-flex text-[9px] font-black rounded-md bg-amber-50 text-amber-600 border border-amber-100 uppercase tracking-widest mt-1.5 shadow-sm">Pending</span></div>
                                    </div>
                                </td>
                                <td class="px-8 py-6"><div class="text-sm font-bold text-slate-900">{{user.Contact}}</div><div class="text-xs text-slate-500 font-bold mt-1 truncate max-w-[200px]">{{user.FullAddress}}</div></td>
                                <td class="px-8 py-6"><span class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-mono font-bold text-slate-700 shadow-sm">{{user.Username}}</span></td>
                                <td class="px-8 py-6 text-right flex justify-end gap-3">
                                    <button ng-click="verifyUser(user)" class="px-6 py-2.5 bg-slate-900 text-white hover:bg-indigo-600 rounded-xl font-bold text-xs transition-all shadow-lg active:scale-95">Approve</button>
                                    <button ng-click="rejectUser(user)" class="px-6 py-2.5 bg-white text-rose-600 border-2 border-slate-100 hover:border-rose-200 hover:bg-rose-50 rounded-xl font-bold text-xs transition-all active:scale-95 shadow-sm">Reject</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div ng-show="(userArray | filter:{Role:'Resident', Status:'Pending'}).length == 0" class="text-center py-24">
                    <div class="inline-flex items-center justify-center h-20 w-20 rounded-3xl bg-white text-emerald-500 mb-6 border border-slate-100 shadow-xl"><i class="material-icons text-4xl">done_all</i></div>
                    <h3 class="text-xl font-black text-slate-900 mb-2 tracking-tight">Inbox Zero</h3>
                    <p class="text-sm text-slate-500 font-bold">No pending registrations require your attention.</p>
                </div>
            </div>
            <footer class="mt-auto pt-4 text-center"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">© 2026 B-Serve Admin Command Center.</p></footer>
        </div>
    </main>
</div>