@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">

    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Verified Residents</h2>
            <p class="text-gray-500">Manage approved barangay members.</p>
        </div>
        <div class="flex gap-3">
            <button ng-click="goTo('HomeDashboard')" class="px-4 py-2 bg-gray-200 text-gray-700 font-bold rounded-lg hover:bg-gray-300 transition-colors">Back</button>
            <button ng-click="openAddUserForm()" ng-hide="showUserForm" class="px-4 py-2 bg-brand-600 text-white font-bold rounded-lg hover:bg-brand-700 shadow-sm transition-colors flex items-center">
                <i class="material-icons mr-1 text-sm">person_add</i> Add Resident
            </button>
        </div>
    </div>

    <div ng-show="showUserForm" class="bg-white rounded-xl shadow-lg border border-brand-200 p-6 mb-8 transform transition-all">
        <h3 class="text-xl font-bold text-brand-700 mb-6 flex items-center border-b pb-3">
            <i class="material-icons mr-2">edit_note</i> {{ userEditMode ? 'Edit Resident Details' : 'Register New Resident Manually' }}
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
            <div><label class="block text-sm text-gray-600 mb-1">First Name</label><input type="text" ng-model="tempUser.FirstName" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div><label class="block text-sm text-gray-600 mb-1">Middle Name</label><input type="text" ng-model="tempUser.MiddleName" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div><label class="block text-sm text-gray-600 mb-1">Last Name</label><input type="text" ng-model="tempUser.LastName" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>

            <div><label class="block text-sm text-gray-600 mb-1">Contact No.</label><input type="text" ng-model="tempUser.Contact" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">Gender</label>
                <select ng-model="tempUser.Gender" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none bg-white">
                    <option value="" disabled selected>Select Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                </select>
            </div>
            <div><label class="block text-sm text-gray-600 mb-1">Full Address</label><input type="text" ng-model="tempUser.FullAddress" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>

            <div><label class="block text-sm text-gray-600 mb-1">Username</label><input type="text" ng-model="tempUser.Username" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div><label class="block text-sm text-gray-600 mb-1">Password</label><input type="text" ng-model="tempUser.Password" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none"></div>
        </div>

        <div class="flex gap-3">
            <button ng-click="adminSaveUser()" class="px-6 py-2 bg-emerald-600 text-white font-bold rounded-md hover:bg-emerald-700">SAVE RECORD</button>
            <button ng-click="showUserForm = false" class="px-6 py-2 bg-gray-100 text-gray-700 font-bold rounded-md hover:bg-gray-200 border">CANCEL</button>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-200">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Name</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Contact & Address</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Account</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <tr ng-repeat="user in userArray | filter:{Role:'Resident', Status:'Verified'}" class="hover:bg-gray-50">
                        <td class="px-6 py-4">
                            <div class="font-bold text-gray-900">{{user.FirstName}} {{user.LastName}}</div>
                            <div class="text-sm text-gray-500">{{user.Gender}}</div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-900">{{user.Contact}}</div>
                            <div class="text-xs text-gray-500">{{user.FullAddress}}</div>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-700">{{user.Username}}</td>
                        <td class="px-6 py-4 flex gap-2">
                            <button ng-click="triggerEditUser(user)" class="p-2 text-brand-600 bg-brand-50 hover:bg-brand-100 rounded-md" title="Edit"><i class="material-icons text-sm">edit</i></button>
                            <button ng-click="deleteUser(user)" class="p-2 text-red-600 bg-red-50 hover:bg-red-100 rounded-md" title="Delete"><i class="material-icons text-sm">delete</i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div ng-show="(userArray | filter:{Role:'Resident', Status:'Verified'}).length == 0" class="text-center py-12">
            <i class="material-icons text-gray-300 text-5xl mb-2">folder_off</i>
            <p class="text-gray-500">No verified residents found.</p>
        </div>
    </div>
</div>