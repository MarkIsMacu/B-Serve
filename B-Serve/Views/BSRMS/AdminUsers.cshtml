@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="flex h-screen bg-slate-50 font-sans overflow-hidden selection:bg-indigo-500/30 relative">
    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-indigo-400/20 rounded-full mix-blend-multiply filter blur-[120px] pointer-events-none"></div>

    <aside class="w-[280px] bg-[#09090b] text-white flex flex-col hidden md:flex z-20 relative border-r border-slate-800">
        <div class="absolute top-[-10%] left-[-10%] w-[300px] h-[300px] bg-indigo-600/30 rounded-full mix-blend-screen filter blur-[80px] pointer-events-none"></div>
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20 mix-blend-overlay pointer-events-none"></div>
        <div class="h-24 flex items-center px-8 border-b border-white/10 relative z-10"><div class="h-10 w-10 bg-gradient-to-br from-blue-600 via-indigo-600 to-violet-600 rounded-xl flex items-center justify-center mr-3 shadow-lg ring-2 ring-white/20"><i class="material-icons text-white text-[20px]">holiday_village</i></div><span class="text-xl font-black tracking-widest uppercase">B-SERVE</span></div>
        <div class="px-6 py-8 relative z-10">
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 pl-1">Administration</p>
            <nav class="space-y-2">
                <a href="#" ng-click="goTo('HomeDashboard')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">dashboard</i> Dashboard</a>
                <a href="#" ng-click="goTo('AdminApproval')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">how_to_reg</i> Approvals</a>
                <a href="#" class="flex items-center px-4 py-3 bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 text-white rounded-2xl font-bold transition-all shadow-lg shadow-indigo-500/25"><i class="material-icons mr-3 text-white text-[20px]">people</i> Directory</a>
                <a href="#" ng-click="goTo('AdminRequest')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">assignment</i> Requests</a>
            </nav>
        </div>
        <div class="mt-auto p-6 relative z-10 border-t border-white/10"><button ng-click="goTo('LogIn')" class="flex items-center justify-center w-full px-4 py-3 bg-white/5 text-slate-300 hover:text-white hover:bg-rose-500/80 rounded-2xl font-bold transition-all"><i class="material-icons mr-2 text-[20px]">logout</i> Sign Out</button></div>
    </aside>

    <main class="flex-1 flex flex-col relative animate-slide-up overflow-y-auto z-10">
        <header class="h-24 bg-white/60 backdrop-blur-2xl border-b border-white sticky top-0 z-30 flex items-center justify-between px-10 shadow-[0_4px_30px_rgb(0,0,0,0.03)]">
            <div><h1 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-slate-900 to-slate-700 tracking-tight">Resident Directory</h1></div>
            <button ng-click="openAddUserForm()" ng-hide="showUserForm" class="flex items-center bg-gradient-to-r from-blue-600 to-indigo-600 text-white hover:opacity-90 text-sm font-black rounded-2xl px-6 py-3 transition-all shadow-lg shadow-indigo-500/20 active:scale-95 tracking-wide"><i class="material-icons mr-2 text-[20px]">person_add</i> Encode Resident</button>
        </header>

        <div class="p-10 flex-1 flex flex-col max-w-7xl mx-auto w-full">

            <div ng-show="showUserForm" class="bg-white/80 backdrop-blur-2xl rounded-[2.5rem] border border-white shadow-[0_8px_40px_rgb(0,0,0,0.08)] p-10 mb-8 relative overflow-hidden animate-slide-up">
                <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-blue-500 via-indigo-500 to-violet-500"></div>
                <h3 class="text-2xl font-black text-slate-900 mb-8 flex items-center border-b border-slate-200/60 pb-6"><div class="p-2 bg-indigo-50 rounded-xl mr-4 border border-indigo-100 shadow-sm"><i class="material-icons text-indigo-600 block">manage_accounts</i></div> {{ userEditMode ? 'Modify Resident Data' : 'Manual Resident Encoding' }}</h3>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">First Name <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.FirstName" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>
                    <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Middle Name</label><input type="text" ng-model="tempUser.MiddleName" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>
                    <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Last Name <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.LastName" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>

                    <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Contact No. <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.Contact" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold font-mono tracking-widest shadow-sm"></div>
                    <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Gender <span class="text-rose-500">*</span></label><select ng-model="tempUser.Gender" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold appearance-none shadow-sm"><option value="" disabled>Select</option><option value="Male">Male</option><option value="Female">Female</option></select></div>

                    <div class="md:col-span-3 grid grid-cols-3 gap-6 pt-6 border-t border-slate-100/60">
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">House/Blk/Lot <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.BlkLot" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Street <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.Street" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Purok <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.Purok" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>
                    </div>

                    <div class="md:col-span-1 pt-6 border-t border-slate-100/60"><label class="block text-[10px] font-black text-indigo-500 uppercase tracking-widest mb-2 pl-1">System Username <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.Username" maxlength="15" class="w-full px-5 py-4 rounded-2xl bg-indigo-50/30 border-2 border-indigo-100 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold shadow-sm"></div>
                    <div class="md:col-span-2 pt-6 border-t border-slate-100/60"><label class="block text-[10px] font-black text-indigo-500 uppercase tracking-widest mb-2 pl-1">Secure Password <span class="text-rose-500">*</span></label><input type="text" ng-model="tempUser.Password" maxlength="20" placeholder="8+ Chars, 1 Upper, 1 Lower, 1 Special" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all font-bold placeholder-slate-300 shadow-sm"></div>
                </div>

                <div class="flex gap-4">
                    <button ng-click="adminSaveUser()" class="px-8 py-4 bg-slate-900 text-white font-black uppercase tracking-widest rounded-2xl shadow-xl shadow-slate-900/20 hover:bg-indigo-600 text-xs transition-all active:scale-95 border border-slate-800">Save Record</button>
                    <button ng-click="showUserForm = false" class="px-8 py-4 bg-white text-slate-500 border-2 border-slate-100 font-black uppercase tracking-widest rounded-2xl hover:bg-slate-50 hover:text-slate-700 text-xs transition-all active:scale-95 shadow-sm">Cancel</button>
                </div>
            </div>

            <div class="bg-white/70 backdrop-blur-2xl rounded-[2.5rem] border border-white shadow-[0_8px_40px_rgb(0,0,0,0.06)] overflow-hidden mb-8">
                <div class="overflow-x-auto">
                    <table class="min-w-full text-left">
                        <thead class="bg-white/50 border-b border-slate-100">
                            <tr><th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Resident Details</th><th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Contact & Location</th><th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Account</th><th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th></tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100/50">
                            <tr ng-repeat="user in userArray | filter:{Role:'Resident', Status:'Verified'} track by $index" class="hover:bg-white/50 transition-colors group">
                                <td class="px-8 py-6"><div class="font-black text-slate-900 text-sm">{{user.FirstName}} {{user.LastName}}</div><div class="text-[9px] font-black text-emerald-600 uppercase tracking-widest mt-1.5 border border-emerald-200 bg-emerald-50 inline-block px-2 py-1 rounded-md shadow-sm">Active</div></td>
                                <td class="px-8 py-6"><div class="text-sm font-bold text-slate-800">{{user.Contact}}</div><div class="text-xs text-slate-500 font-bold mt-1 truncate max-w-[200px]">{{user.FullAddress}}</div></td>
                                <td class="px-8 py-6"><span class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-mono font-bold text-slate-700 shadow-sm">{{user.Username}}</span></td>
                                <td class="px-8 py-6 text-right flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button ng-click="triggerEditUser(user)" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors"><i class="material-icons text-[20px]">edit</i></button>
                                    <button ng-click="deleteUser(user)" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-colors"><i class="material-icons text-[20px]">delete_outline</i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <footer class="mt-auto pt-4 text-center"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">© 2026 B-Serve Admin Command Center.</p></footer>
        </div>
    </main>
</div>