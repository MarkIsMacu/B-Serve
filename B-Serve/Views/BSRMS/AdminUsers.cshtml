@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="flex h-screen bg-gray-50 font-sans overflow-hidden">

    <aside class="w-64 bg-gray-900 text-white flex flex-col shadow-2xl hidden md:flex z-20">
        <div class="h-20 flex items-center px-6 border-b border-gray-800 bg-gray-950"><i class="material-icons text-brand-500 mr-3 text-3xl">admin_panel_settings</i><span class="text-xl font-bold tracking-wider">B-SERVE</span></div>
        <nav class="flex-1 px-4 py-6 space-y-3">
            <a href="#" ng-click="goTo('HomeDashboard')" class="flex items-center px-4 py-3 text-gray-400 hover:bg-gray-800 hover:text-white rounded-xl transition-all hover:translate-x-1"><i class="material-icons mr-3">dashboard</i> Dashboard</a>
            <a href="#" ng-click="goTo('AdminApproval')" class="flex items-center px-4 py-3 text-gray-400 hover:bg-gray-800 hover:text-white rounded-xl transition-all hover:translate-x-1"><i class="material-icons mr-3">how_to_reg</i> Pending Approvals</a>

            <a href="#" class="flex items-center px-4 py-3 bg-brand-600 text-white rounded-xl shadow-lg shadow-brand-500/30 transition-all"><i class="material-icons mr-3">people</i> Verified Residents</a>

            <a href="#" ng-click="goTo('AdminRequest')" class="flex items-center px-4 py-3 text-gray-400 hover:bg-gray-800 hover:text-white rounded-xl transition-all hover:translate-x-1"><i class="material-icons mr-3">assignment</i> Manage Requests</a>
        </nav>
        <div class="p-4 border-t border-gray-800 bg-gray-950"><button ng-click="goTo('Login')" class="flex items-center w-full px-4 py-3 text-red-400 hover:bg-red-500 hover:text-white rounded-xl transition-all font-bold group"><i class="material-icons mr-3 group-hover:-translate-x-1 transition-transform">logout</i> Sign Out</button></div>
    </aside>

    <main class="flex-1 flex flex-col relative animate-slide-up">

        <header class="h-20 bg-white/80 backdrop-blur-md flex items-center justify-between px-8 border-b border-gray-200 z-10 sticky top-0">
            <div><h2 class="text-2xl font-extrabold text-gray-800 tracking-tight">Verified Resident Directory</h2><p class="text-sm text-gray-500">Manage and update approved community members.</p></div>
            <button ng-click="openAddUserForm()" ng-hide="showUserForm" class="px-6 py-2.5 bg-brand-600 text-white font-bold rounded-xl shadow-lg shadow-brand-500/30 hover:bg-brand-500 hover:-translate-y-0.5 transition-all flex items-center">
                <i class="material-icons mr-2 text-sm">person_add</i> Add Resident
            </button>
        </header>

        <div class="flex-1 overflow-y-auto p-8">

            <div ng-show="showUserForm" class="bg-white rounded-2xl shadow-2xl border border-brand-200 p-8 mb-8 relative overflow-hidden animate-slide-up">
                <div class="absolute top-0 left-0 w-2 h-full bg-brand-500"></div>
                <h3 class="text-2xl font-black text-gray-800 mb-8 flex items-center border-b border-gray-100 pb-4">
                    <span class="bg-brand-100 text-brand-600 p-2 rounded-lg mr-3 shadow-inner"><i class="material-icons block">manage_accounts</i></span>
                    {{ userEditMode ? 'Edit Resident Profile' : 'Register Resident Manually' }}
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">First Name</label><input type="text" ng-model="tempUser.FirstName" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Middle Name</label><input type="text" ng-model="tempUser.MiddleName" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Last Name</label><input type="text" ng-model="tempUser.LastName" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>

                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Contact No.</label><input type="text" ng-model="tempUser.Contact" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Gender</label><select ng-model="tempUser.Gender" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all bg-white cursor-pointer"><option value="" disabled selected>Select Gender</option><option value="Male">Male</option><option value="Female">Female</option></select></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Barangay Address</label><input type="text" ng-model="tempUser.FullAddress" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>

                    <div class="md:col-span-1 border-t border-gray-100 pt-6 mt-2"><label class="block text-sm font-bold text-brand-700 mb-2"><i class="material-icons text-xs mr-1">vpn_key</i> Username</label><input type="text" ng-model="tempUser.Username" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>
                    <div class="md:col-span-2 border-t border-gray-100 pt-6 mt-2"><label class="block text-sm font-bold text-brand-700 mb-2"><i class="material-icons text-xs mr-1">password</i> Password</label><input type="text" ng-model="tempUser.Password" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-4 focus:ring-brand-500/20 focus:border-brand-500 bg-gray-50 focus:bg-white outline-none transition-all"></div>
                </div>

                <div class="flex gap-4">
                    <button ng-click="adminSaveUser()" class="px-8 py-3.5 bg-emerald-600 text-white font-bold rounded-xl shadow-lg shadow-emerald-500/30 hover:bg-emerald-500 transform hover:-translate-y-1 transition-all">SAVE RECORD</button>
                    <button ng-click="showUserForm = false" class="px-8 py-3.5 bg-white text-gray-700 font-bold rounded-xl border-2 border-gray-200 hover:bg-gray-50 transition-all">CANCEL</button>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-4 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Resident Details</th>
                                <th class="px-6 py-4 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Contact & Location</th>
                                <th class="px-6 py-4 text-left text-xs font-black text-gray-500 uppercase tracking-wider">System Account</th>
                                <th class="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider pr-8">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            <tr ng-repeat="user in userArray | filter:{Role:'Resident', Status:'Verified'}" class="hover:bg-brand-50/30 transition-colors duration-200 group">
                                <td class="px-6 py-5">
                                    <div class="font-bold text-gray-900 text-base">{{user.FirstName}} {{user.LastName}}</div>
                                    <div class="text-xs font-bold text-emerald-600 mt-1 flex items-center"><i class="material-icons text-[10px] mr-1">verified_user</i> Verified Active</div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="text-sm font-bold text-gray-800"><i class="material-icons text-[12px] text-gray-400 mr-1">phone</i>{{user.Contact}}</div>
                                    <div class="text-xs text-gray-500 mt-1 max-w-[200px] truncate" title="{{user.FullAddress}}"><i class="material-icons text-[12px] text-gray-400 mr-1">place</i>{{user.FullAddress}}</div>
                                </td>
                                <td class="px-6 py-5"><span class="text-sm font-mono bg-gray-100 border border-gray-200 px-3 py-1.5 rounded-lg text-gray-700 shadow-sm">{{user.Username}}</span></td>
                                <td class="px-6 py-5 text-right">
                                    <button ng-click="triggerEditUser(user)" class="p-2.5 text-brand-600 bg-brand-50 hover:bg-brand-500 hover:text-white rounded-xl shadow-sm hover:shadow-lg hover:shadow-brand-500/30 transition-all mr-2" title="Edit"><i class="material-icons text-sm">edit</i></button>
                                    <button ng-click="deleteUser(user)" class="p-2.5 text-red-600 bg-red-50 hover:bg-red-500 hover:text-white rounded-xl shadow-sm hover:shadow-lg hover:shadow-red-500/30 transition-all" title="Delete"><i class="material-icons text-sm">delete_outline</i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div ng-show="(userArray | filter:{Role:'Resident', Status:'Verified'}).length == 0" class="text-center py-20 bg-gray-50/50">
                    <div class="inline-flex items-center justify-center h-24 w-24 rounded-full bg-gray-100 text-gray-400 mb-6 border-2 border-dashed border-gray-300"><i class="material-icons text-5xl">folder_off</i></div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">No Verified Residents</h3>
                    <p class="text-gray-500">The resident directory is currently empty.</p>
                </div>
            </div>
        </div>
    </main>
</div>