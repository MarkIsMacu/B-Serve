@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="flex h-screen bg-gray-50 font-sans overflow-hidden">

    <aside class="w-64 bg-gray-900 text-white flex flex-col shadow-2xl hidden md:flex z-20">
        <div class="h-20 flex items-center px-6 border-b border-gray-800 bg-gray-950"><i class="material-icons text-brand-500 mr-3 text-3xl">admin_panel_settings</i><span class="text-xl font-bold tracking-wider">B-SERVE</span></div>
        <nav class="flex-1 px-4 py-6 space-y-3">
            <a href="#" ng-click="goTo('HomeDashboard')" class="flex items-center px-4 py-3 text-gray-400 hover:bg-gray-800 hover:text-white rounded-xl transition-all hover:translate-x-1"><i class="material-icons mr-3">dashboard</i> Dashboard</a>
            <a href="#" ng-click="goTo('AdminApproval')" class="flex items-center px-4 py-3 text-gray-400 hover:bg-gray-800 hover:text-white rounded-xl transition-all hover:translate-x-1"><i class="material-icons mr-3">how_to_reg</i> Pending Approvals</a>
            <a href="#" ng-click="goTo('AdminUsers')" class="flex items-center px-4 py-3 text-gray-400 hover:bg-gray-800 hover:text-white rounded-xl transition-all hover:translate-x-1"><i class="material-icons mr-3">people</i> Verified Residents</a>

            <a href="#" class="flex items-center px-4 py-3 bg-brand-600 text-white rounded-xl shadow-lg shadow-brand-500/30 transition-all"><i class="material-icons mr-3">assignment</i> Manage Requests</a>
        </nav>
        <div class="p-4 border-t border-gray-800 bg-gray-950"><button ng-click="goTo('Login')" class="flex items-center w-full px-4 py-3 text-red-400 hover:bg-red-500 hover:text-white rounded-xl transition-all font-bold group"><i class="material-icons mr-3 group-hover:-translate-x-1 transition-transform">logout</i> Sign Out</button></div>
    </aside>

    <main class="flex-1 flex flex-col relative animate-slide-up">

        <header class="h-20 bg-white/80 backdrop-blur-md flex items-center justify-between px-8 border-b border-gray-200 z-10 sticky top-0">
            <div><h2 class="text-2xl font-extrabold text-gray-800 tracking-tight">Request Tracking Board</h2><p class="text-sm text-gray-500">Update statuses for resident documents and complaints.</p></div>
            <button ng-click="openAddReqForm()" ng-hide="showReqForm" class="px-6 py-2.5 bg-gray-900 text-white font-bold rounded-xl shadow-lg shadow-gray-900/30 hover:bg-gray-800 hover:-translate-y-0.5 transition-all flex items-center">
                <i class="material-icons mr-2 text-sm">add_circle</i> Log Manual Request
            </button>
        </header>

        <div class="flex-1 overflow-y-auto p-8">

            <div ng-show="showReqForm" class="bg-white rounded-2xl shadow-2xl border border-gray-200 p-8 mb-8 relative overflow-hidden animate-slide-up">
                <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-brand-400 to-indigo-500"></div>
                <h3 class="text-2xl font-black text-gray-800 mb-8 flex items-center border-b border-gray-100 pb-4 mt-2">
                    <span class="bg-indigo-50 text-indigo-600 p-2 rounded-lg mr-3 shadow-inner border border-indigo-100"><i class="material-icons block">edit_document</i></span>
                    {{ reqEditMode ? 'Update Request Status' : 'Create Manual Request' }}
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Category Type</label>
                        <select ng-model="tempReq.Type" class="w-full px-4 py-3.5 rounded-xl border border-gray-300 focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 bg-gray-50 focus:bg-white outline-none transition-all cursor-pointer">
                            <option value="" disabled selected>Select Category Type</option>
                            <option value="Document Request">Document Request</option>
                            <option value="Complaint">Complaint</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Current Status Update</label>
                        <select ng-model="tempReq.Status" class="w-full px-4 py-3.5 rounded-xl border border-gray-300 focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 bg-gray-50 focus:bg-white outline-none transition-all cursor-pointer">
                            <option value="Pending">Pending (Awaiting Review)</option>
                            <option value="On-going">On-going (Processing)</option>
                            <option value="Resolved">Resolved (Completed)</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-gray-700 mb-2">Message / Detailed Request</label>
                        <textarea ng-model="tempReq.Message" class="w-full px-4 py-4 rounded-xl border border-gray-300 focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 bg-gray-50 focus:bg-white outline-none min-h-[120px] transition-all resize-none"></textarea>
                    </div>
                </div>

                <div class="flex gap-4">
                    <button ng-click="adminSaveRequest()" class="px-8 py-3.5 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/30 hover:bg-indigo-500 transform hover:-translate-y-1 transition-all">SAVE UPDATE</button>
                    <button ng-click="showReqForm = false" class="px-8 py-3.5 bg-white text-gray-700 font-bold rounded-xl border-2 border-gray-200 hover:bg-gray-50 transition-all">CANCEL</button>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-4 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Requested By</th>
                                <th class="px-6 py-4 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Submission Details</th>
                                <th class="px-6 py-4 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Current Status</th>
                                <th class="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider pr-8">Manage</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            <tr ng-repeat="req in requestArray" class="hover:bg-gray-50/80 transition-colors duration-200 group">
                                <td class="px-6 py-5">
                                    <div class="flex items-center">
                                        <i class="material-icons text-gray-400 mr-3 text-3xl">account_circle</i>
                                        <span class="font-bold text-gray-900">{{req.Sender}}</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-gray-100 text-gray-600 border border-gray-200 mb-2 uppercase tracking-wide"><i class="material-icons text-[12px] mr-1">sell</i>{{req.Type}}</span>
                                    <div class="text-sm text-gray-700 max-w-md pr-10 leading-relaxed">{{req.Message}}</div>
                                </td>
                                <td class="px-6 py-5">
                                    <span ng-show="req.Status == 'Pending'" class="px-4 py-1.5 inline-flex text-xs font-black rounded-full bg-amber-100 text-amber-800 border border-amber-200 shadow-sm items-center"><i class="material-icons text-[12px] mr-1">schedule</i> Pending</span>
                                    <span ng-show="req.Status == 'On-going'" class="px-4 py-1.5 inline-flex text-xs font-black rounded-full bg-brand-100 text-brand-800 border border-brand-200 shadow-sm items-center"><i class="material-icons text-[12px] mr-1">sync</i> On-going</span>
                                    <span ng-show="req.Status == 'Resolved'" class="px-4 py-1.5 inline-flex text-xs font-black rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm items-center"><i class="material-icons text-[12px] mr-1">done_all</i> Resolved</span>
                                </td>
                                <td class="px-6 py-5 text-right">
                                    <button ng-click="triggerEditRequest(req)" class="px-4 py-2 text-indigo-700 bg-indigo-50 hover:bg-indigo-600 hover:text-white rounded-xl shadow-sm hover:shadow-lg hover:shadow-indigo-500/30 transition-all font-bold text-sm mr-2">Update</button>
                                    <button ng-click="deleteRequest(req)" class="p-2.5 text-red-600 bg-red-50 hover:bg-red-500 hover:text-white rounded-xl shadow-sm hover:shadow-lg hover:shadow-red-500/30 transition-all" title="Delete Log"><i class="material-icons text-sm">delete_outline</i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div ng-show="requestArray.length == 0" class="text-center py-20 bg-gray-50/50">
                    <div class="inline-flex items-center justify-center h-24 w-24 rounded-full bg-indigo-50 text-indigo-300 mb-6 border-2 border-dashed border-indigo-200"><i class="material-icons text-5xl">receipt_long</i></div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">No active requests</h3>
                    <p class="text-gray-500">When residents submit documents or complaints, they will appear here.</p>
                </div>
            </div>
        </div>
    </main>
</div>