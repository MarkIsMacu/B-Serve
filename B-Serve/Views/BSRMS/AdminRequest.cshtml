@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">

    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Request Management</h2>
            <p class="text-gray-500">Update resident documents and complaints.</p>
        </div>
        <div class="flex gap-3">
            <button ng-click="goTo('HomeDashboard')" class="px-4 py-2 bg-gray-200 text-gray-700 font-bold rounded-lg hover:bg-gray-300 transition-colors">Back</button>
            <button ng-click="openAddReqForm()" ng-hide="showReqForm" class="px-4 py-2 bg-brand-600 text-white font-bold rounded-lg hover:bg-brand-700 shadow-sm transition-colors flex items-center">
                <i class="material-icons mr-1 text-sm">add_circle</i> Log Manual Request
            </button>
        </div>
    </div>

    <div ng-show="showReqForm" class="bg-white rounded-xl shadow-lg border border-brand-200 p-6 mb-8 transform transition-all">
        <h3 class="text-xl font-bold text-brand-700 mb-6 flex items-center border-b pb-3">
            <i class="material-icons mr-2">edit_document</i> {{ reqEditMode ? 'Update Request Status' : 'Create Manual Request' }}
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
            <div>
                <label class="block text-sm text-gray-600 mb-1">Category Type</label>
                <select ng-model="tempReq.Type" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none bg-white">
                    <option value="" disabled selected>Select Type</option>
                    <option value="Document Request">Document Request</option>
                    <option value="Complaint">Complaint</option>
                </select>
            </div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">Current Status</label>
                <select ng-model="tempReq.Status" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none bg-white">
                    <option value="Pending">Pending</option>
                    <option value="On-going">On-going</option>
                    <option value="Resolved">Resolved</option>
                </select>
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm text-gray-600 mb-1">Message / Details</label>
                <textarea ng-model="tempReq.Message" class="w-full px-3 py-2 rounded-md border focus:ring-2 focus:ring-brand-500 outline-none min-h-[100px]"></textarea>
            </div>
        </div>

        <div class="flex gap-3">
            <button ng-click="adminSaveRequest()" class="px-6 py-2 bg-emerald-600 text-white font-bold rounded-md hover:bg-emerald-700">SAVE REQUEST</button>
            <button ng-click="showReqForm = false" class="px-6 py-2 bg-gray-100 text-gray-700 font-bold rounded-md hover:bg-gray-200 border">CANCEL</button>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-200">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Sender</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Type & Message</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <tr ng-repeat="req in requestArray" class="hover:bg-gray-50">
                        <td class="px-6 py-4 font-medium text-gray-900">{{req.Sender}}</td>
                        <td class="px-6 py-4">
                            <span class="inline-block px-2 py-1 bg-gray-100 text-xs text-gray-600 rounded mb-1 border border-gray-200">{{req.Type}}</span>
                            <div class="text-sm text-gray-700 max-w-md truncate" title="{{req.Message}}">{{req.Message}}</div>
                        </td>
                        <td class="px-6 py-4">
                            <span ng-show="req.Status == 'Pending'" class="px-3 py-1 text-xs font-bold rounded-full bg-amber-100 text-amber-800 border border-amber-200">Pending</span>
                            <span ng-show="req.Status == 'On-going'" class="px-3 py-1 text-xs font-bold rounded-full bg-brand-100 text-brand-800 border border-brand-200">On-going</span>
                            <span ng-show="req.Status == 'Resolved'" class="px-3 py-1 text-xs font-bold rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">Resolved</span>
                        </td>
                        <td class="px-6 py-4 flex gap-2">
                            <button ng-click="triggerEditRequest(req)" class="p-2 text-brand-600 bg-brand-50 hover:bg-brand-100 rounded-md" title="Update Status"><i class="material-icons text-sm">edit</i></button>
                            <button ng-click="deleteRequest(req)" class="p-2 text-red-600 bg-red-50 hover:bg-red-100 rounded-md" title="Delete"><i class="material-icons text-sm">delete</i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div ng-show="requestArray.length == 0" class="text-center py-12">
            <i class="material-icons text-gray-300 text-5xl mb-2">inbox</i>
            <p class="text-gray-500">No requests logged yet.</p>
        </div>
    </div>
</div>