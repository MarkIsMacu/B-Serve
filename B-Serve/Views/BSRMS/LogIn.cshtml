@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="min-h-screen relative flex items-center justify-center overflow-hidden bg-gradient-to-br from-gray-900 via-brand-900 to-indigo-900">

    <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-brand-500 rounded-full mix-blend-screen filter blur-[100px] opacity-30 animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-emerald-500 rounded-full mix-blend-screen filter blur-[100px] opacity-20 animate-pulse"></div>

    <div class="max-w-md w-full mx-4 relative z-10 bg-white/10 backdrop-blur-xl rounded-[2rem] shadow-2xl p-10 border border-white/20 animate-slide-up">

        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center h-20 w-20 rounded-2xl bg-white/20 text-white mb-6 shadow-inner border border-white/30 backdrop-blur-md transform hover:scale-110 transition-transform duration-500">
                <i class="material-icons text-5xl">admin_panel_settings</i>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight drop-shadow-md">B-Serve</h2>
            <p class="mt-2 text-brand-100 font-medium tracking-wide">Barangay Service Portal</p>
        </div>

        <div class="space-y-6">
            <div class="group relative">
                <label class="block text-xs font-bold text-brand-100 uppercase tracking-wider mb-2">Username</label>
                <input type="text" ng-model="LoginUser" maxlength="15" class="w-full px-5 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/40 focus:bg-white/20 focus:border-white/50 focus:ring-4 focus:ring-white/10 outline-none transition-all duration-300 backdrop-blur-sm" placeholder="Enter username">
            </div>

            <div class="group relative">
                <label class="block text-xs font-bold text-brand-100 uppercase tracking-wider mb-2">Password</label>
                <input type="password" ng-model="LoginPass" maxlength="15" class="w-full px-5 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/40 focus:bg-white/20 focus:border-white/50 focus:ring-4 focus:ring-white/10 outline-none transition-all duration-300 backdrop-blur-sm" placeholder="••••••••">
            </div>

            <button ng-click="login()" class="w-full flex justify-center items-center py-4 px-4 rounded-xl font-black text-brand-900 bg-white hover:bg-brand-50 focus:outline-none focus:ring-4 focus:ring-white/30 shadow-[0_0_20px_rgba(255,255,255,0.3)] transform hover:-translate-y-1 transition-all duration-300 mt-4">
                SECURE LOGIN <i class="material-icons ml-2 text-sm">arrow_forward</i>
            </button>
        </div>

        <div class="mt-8 text-center pt-6 border-t border-white/10">
            <p class="text-sm text-brand-100">
                New resident?
                <a href="#" ng-click="goTo('Registration')" class="font-bold text-white hover:text-brand-200 hover:underline transition-colors decoration-2 underline-offset-4">Create an account</a>
            </p>
        </div>

    </div>
</div>