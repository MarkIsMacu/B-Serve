@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="min-h-screen bg-slate-50 font-sans relative flex flex-col selection:bg-indigo-500/30 overflow-x-hidden" ng-init="loadMyRequests()">

    <div class="absolute top-0 left-0 w-full h-[400px] bg-[#09090b] z-0 border-b border-slate-800 overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20 mix-blend-overlay pointer-events-none"></div>
        <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] bg-indigo-600/30 rounded-full mix-blend-screen filter blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-[500px] h-[500px] bg-violet-600/30 rounded-full mix-blend-screen filter blur-[120px] pointer-events-none"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto w-full py-10 px-4 sm:px-6 lg:px-8 flex-1 flex flex-col animate-slide-up">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 pt-6">
            <div>
                <h1 class="text-4xl font-black text-white tracking-tight flex items-center"><div class="h-12 w-12 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center mr-4 border border-white/20 shadow-lg"><i class="material-icons text-white text-[24px]">holiday_village</i></div> Resident Hub</h1>
                <p class="text-indigo-200/80 mt-2 text-sm font-bold tracking-widest uppercase ml-[4.5rem]">Secure Barangay Services</p>
            </div>
            <button ng-click="goTo('LogIn')" class="mt-6 md:mt-0 flex items-center px-6 py-3.5 bg-white/10 text-white font-black uppercase tracking-widest rounded-2xl hover:bg-rose-500 hover:border-transparent transition-all border border-white/20 text-xs shadow-lg backdrop-blur-md">
                <i class="material-icons mr-2 text-[18px]">logout</i> Sign Out
            </button>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-12">

            <div class="lg:col-span-5">
                <div class="bg-white/70 backdrop-blur-2xl rounded-[3rem] shadow-[0_8px_40px_rgb(0,0,0,0.06)] p-10 border border-white sticky top-10">
                    <h3 class="text-2xl font-black text-slate-900 mb-8 flex items-center border-b border-slate-200/60 pb-6"><div class="p-2 bg-indigo-50 rounded-xl mr-4 border border-indigo-100 shadow-sm"><i class="material-icons text-indigo-600 align-text-bottom text-[22px] block">edit_document</i></div> File New Request</h3>

                    <div class="space-y-6">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Category <span class="text-rose-500">*</span></label>
                            <select ng-model="ReqType" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all appearance-none font-bold text-slate-900 shadow-sm">
                                <option value="" disabled selected>-- Select an option --</option>
                                <option value="Barangay Clearance">Barangay Clearance</option>
                                <option value="Certificate of Indigency">Certificate of Indigency</option>
                                <option value="Business Permit">Business Permit</option>
                                <option value="General Complaint">General Complaint</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Details <span class="text-rose-500">*</span></label>
                            <textarea ng-model="ReqMessage" maxlength="500" placeholder="Please provide required information..." class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all min-h-[140px] resize-none font-bold text-slate-900 shadow-sm"></textarea>
                        </div>

                        <button ng-click="submitRequest()" ng-disabled="!ReqType || !ReqMessage" class="w-full mt-6 py-4 rounded-2xl font-black text-white bg-slate-900 hover:bg-indigo-600 disabled:bg-slate-200 disabled:text-slate-400 shadow-xl shadow-slate-900/20 hover:shadow-indigo-500/30 transition-all text-xs active:scale-[0.98] tracking-widest uppercase border border-slate-800">
                            Submit Form
                        </button>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-7">
                <div class="bg-white/70 backdrop-blur-2xl rounded-[3rem] shadow-[0_8px_40px_rgb(0,0,0,0.06)] p-10 border border-white min-h-[500px] flex flex-col" ng-init="filterStatus = ''">
                    <h3 class="text-2xl font-black text-slate-900 mb-6 flex items-center border-b border-slate-200/60 pb-6"><div class="p-2 bg-emerald-50 rounded-xl mr-4 border border-emerald-100 shadow-sm"><i class="material-icons text-emerald-600 align-text-bottom text-[22px] block">history</i></div> Request History</h3>

                    <!-- Filter Tabs -->
                    <div class="flex flex-wrap gap-2 mb-6">
                        <button ng-click="filterStatus = ''" ng-class="filterStatus === '' ? 'bg-slate-900 text-white shadow-md' : 'bg-white text-slate-500 hover:bg-slate-100 border border-slate-200'" class="px-4 py-2 rounded-xl text-[10px] font-black tracking-widest uppercase transition-all duration-200">All Requests</button>
                        <button ng-click="filterStatus = 'Pending'" ng-class="filterStatus === 'Pending' ? 'bg-amber-500 text-white shadow-md' : 'bg-white text-slate-500 hover:bg-slate-100 border border-slate-200'" class="px-4 py-2 rounded-xl text-[10px] font-black tracking-widest uppercase transition-all duration-200">Pending</button>
                        <button ng-click="filterStatus = 'On-going'" ng-class="filterStatus === 'On-going' ? 'bg-indigo-500 text-white shadow-md' : 'bg-white text-slate-500 hover:bg-slate-100 border border-slate-200'" class="px-4 py-2 rounded-xl text-[10px] font-black tracking-widest uppercase transition-all duration-200">Processing</button>
                        <button ng-click="filterStatus = 'Resolved'" ng-class="filterStatus === 'Resolved' ? 'bg-emerald-500 text-white shadow-md' : 'bg-white text-slate-500 hover:bg-slate-100 border border-slate-200'" class="px-4 py-2 rounded-xl text-[10px] font-black tracking-widest uppercase transition-all duration-200">Resolved</button>
                    </div>

                    <div class="space-y-5 flex-1 overflow-y-auto pr-3 [&::-webkit-scrollbar]:w-1.5 [&::-webkit-scrollbar-track]:bg-transparent [&::-webkit-scrollbar-thumb]:bg-slate-200 hover:[&::-webkit-scrollbar-thumb]:bg-slate-300 [&::-webkit-scrollbar-thumb]:rounded-full pb-4" style="max-height: 550px;">
                        <div ng-repeat="req in myRequests | filter:(filterStatus ? {Status: filterStatus} : {}) track by $index" class="relative group">
                            <div class="bg-white rounded-[2rem] p-7 border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.03)] relative hover:shadow-[0_8px_30px_rgb(99,102,241,0.08)] hover:-translate-y-1 transition-all duration-300">
                                <div class="absolute top-6 right-6">
                                    <span ng-show="req.Status == 'Pending'" class="px-3 py-1.5 text-[9px] font-black rounded-md bg-amber-50 text-amber-600 uppercase tracking-widest border border-amber-100 shadow-sm">Pending</span>
                                    <span ng-show="req.Status == 'On-going'" class="px-3 py-1.5 text-[9px] font-black rounded-md bg-indigo-50 text-indigo-600 uppercase tracking-widest border border-indigo-100 shadow-sm">Processing</span>
                                    <span ng-show="req.Status == 'Resolved'" class="px-3 py-1.5 text-[9px] font-black rounded-md bg-emerald-50 text-emerald-600 uppercase tracking-widest border border-emerald-100 shadow-sm">Resolved</span>
                                </div>

                                <div class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-2"><i class="material-icons text-[14px] align-text-bottom mr-1 text-slate-300">sell</i> {{req.Type}}</div>
                                <p class="text-slate-900 text-sm font-bold pr-20 leading-relaxed">{{req.Message}}</p>

                                <div ng-show="req.AdminFeedback" class="mt-6 p-5 bg-gradient-to-r from-indigo-50/80 to-white border border-indigo-100 rounded-2xl shadow-[0_2px_10px_rgb(0,0,0,0.02)]">
                                    <p class="text-[9px] font-black text-indigo-500 uppercase tracking-widest mb-2 flex items-center"><i class="material-icons text-[14px] mr-1.5 text-indigo-400">forum</i> Admin Reply</p>
                                    <p class="text-slate-700 text-sm font-semibold italic border-l-2 border-indigo-300 pl-3 py-1">{{req.AdminFeedback}}</p>
                                </div>
                            </div>
                        </div>

                        <div ng-show="(myRequests | filter:(filterStatus ? {Status: filterStatus} : {})).length == 0" class="text-center py-20">
                            <div class="inline-flex items-center justify-center h-20 w-20 rounded-3xl bg-white text-slate-300 mb-6 border border-slate-100 shadow-xl"><i class="material-icons text-4xl">inbox</i></div>
                            <h4 class="text-xl font-black text-slate-900 mb-2 tracking-tight">No Requests Found</h4>
                            <p class="text-sm text-slate-500 font-bold">There are no records matching your current filter.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mt-auto border-t border-slate-300/30 pt-6 text-center">
            <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">© 2026 B-Serve Resident Portal.</p>
        </footer>
    </div>
</div>