@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="min-h-screen py-10 px-4">
    <div class="max-w-5xl mx-auto bg-white rounded-2xl shadow-xl p-8 border border-gray-100">

        <div class="text-center mb-10 border-b pb-6">
            <h2 class="text-3xl font-bold text-gray-900">Resident Registration</h2>
            <p class="mt-2 text-gray-500">Please provide accurate details for barangay verification.</p>
        </div>

        <div class="space-y-8">
            <div>
                <h3 class="text-lg font-bold text-brand-600 mb-4 flex items-center">
                    <i class="material-icons mr-2">person</i> Personal Information
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                        <input type="text" ng-model="FName" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Middle Name</label>
                        <input type="text" ng-model="MName" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                        <input type="text" ng-model="LName" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Contact Number</label>
                        <input type="text" ng-model="Contact" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Gender</label>
                        <select ng-model="Gender" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none bg-white">
                            <option value="" disabled selected>Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                </div>
            </div>

            <div>
                <h3 class="text-lg font-bold text-brand-600 mb-4 flex items-center">
                    <i class="material-icons mr-2">home</i> Barangay Address
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">House / Block / Lot</label>
                        <input type="text" ng-model="BlkLot" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Street Name</label>
                        <input type="text" ng-model="Street" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Purok / Sitio</label>
                        <input type="text" ng-model="Purok" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                </div>
            </div>

            <div>
                <h3 class="text-lg font-bold text-brand-600 mb-4 flex items-center">
                    <i class="material-icons mr-2">lock</i> Account Details
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                        <input type="text" ng-model="RegUsername" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                        <input type="password" ng-model="RegPassword" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 outline-none">
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <button ng-click="saveUser()" ng-disabled="!isFormValid()" class="px-8 py-3 rounded-lg font-bold text-white bg-green-600 hover:bg-green-700 disabled:opacity-50 disabled:cursor-not-allowed shadow-md transition-all">
                SUBMIT REGISTRATION
            </button>
            <button ng-click="goTo('Login')" class="px-8 py-3 rounded-lg font-bold text-gray-700 bg-gray-200 hover:bg-gray-300 shadow-sm transition-all">
                BACK TO LOGIN
            </button>
        </div>

    </div>
</div>