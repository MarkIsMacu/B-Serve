@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<div class="min-h-screen bg-slate-50 font-sans relative selection:bg-indigo-500/30 pb-20">

    <div class="w-full h-[450px] bg-[#09090b] relative overflow-hidden">
        <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] bg-indigo-600/30 rounded-full mix-blend-screen filter blur-[120px]"></div>
        <div class="absolute bottom-[-20%] right-[10%] w-[500px] h-[500px] bg-violet-600/30 rounded-full mix-blend-screen filter blur-[120px]"></div>
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-30 mix-blend-overlay pointer-events-none"></div>

        <header class="max-w-6xl mx-auto px-6 lg:px-8 py-8 flex justify-between items-center relative z-20">
            <div class="flex items-center text-white font-black text-2xl tracking-widest uppercase"><div class="h-10 w-10 bg-white/10 backdrop-blur-md rounded-xl flex items-center justify-center mr-4 border border-white/20 shadow-lg"><i class="material-icons text-white text-[22px]">admin_panel_settings</i></div> B-SERVE</div>
            <button ng-click="goTo('LogIn')" class="text-xs font-black text-slate-300 hover:text-white transition-colors flex items-center bg-white/10 backdrop-blur-md border border-white/20 px-5 py-2.5 rounded-xl"><i class="material-icons mr-2 text-[18px]">arrow_back</i> Back to Login</button>
        </header>

        <div class="text-center relative z-20 mt-10">
            <h1 class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400 tracking-tighter mb-4">Resident Registration</h1>
            <p class="text-indigo-200 font-medium text-lg max-w-xl mx-auto">Create your official account to access community services. Fields marked with <span class="text-rose-400 font-black">*</span> are required.</p>
        </div>
    </div>

    <div class="max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8 relative z-30 -mt-32 animate-slide-up">
        <div class="bg-white rounded-[2.5rem] shadow-[0_20px_50px_rgb(0,0,0,0.1)] border border-slate-100 p-8 md:p-12">

            <div class="space-y-10">
                <div>
                    <h3 class="text-sm font-black text-slate-900 mb-6 flex items-center uppercase tracking-widest border-b-2 border-slate-100 pb-4"><div class="p-2 bg-indigo-50 text-indigo-600 rounded-xl mr-4"><i class="material-icons text-[20px]">badge</i></div> Personal Identity</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">First Name <span class="text-rose-500">*</span></label><input type="text" ng-model="FName" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Middle Name</label><input type="text" ng-model="MName" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Last Name <span class="text-rose-500">*</span></label><input type="text" ng-model="LName" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold"></div>

                        <div class="md:col-span-2"><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Contact No. (11 Digits) <span class="text-rose-500">*</span></label><input type="text" ng-model="Contact" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" placeholder="09XX XXX XXXX" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold tracking-widest font-mono"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Gender <span class="text-rose-500">*</span></label><select ng-model="Gender" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold appearance-none"><option value="" disabled selected>Select Gender</option><option value="Male">Male</option><option value="Female">Female</option></select></div>
                    </div>
                </div>

                <div>
                    <h3 class="text-sm font-black text-slate-900 mb-6 flex items-center uppercase tracking-widest border-b-2 border-slate-100 pb-4"><div class="p-2 bg-indigo-50 text-indigo-600 rounded-xl mr-4"><i class="material-icons text-[20px]">home</i></div> Residential Address</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">House/Block/Lot <span class="text-rose-500">*</span></label><input type="text" ng-model="BlkLot" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Street Name <span class="text-rose-500">*</span></label><input type="text" ng-model="Street" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold"></div>
                        <div><label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 pl-1">Purok / Sitio <span class="text-rose-500">*</span></label><input type="text" ng-model="Purok" maxlength="50" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border-2 border-slate-100 text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold"></div>
                    </div>
                </div>

                <div class="bg-indigo-50/50 p-8 rounded-[2rem] border border-indigo-100/50">
                    <h3 class="text-sm font-black text-indigo-900 mb-6 flex items-center uppercase tracking-widest"><div class="p-2 bg-white text-indigo-600 rounded-xl mr-4 shadow-sm"><i class="material-icons text-[20px]">lock</i></div> Secure Credentials</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div><label class="block text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-2 pl-1">Username <span class="text-rose-500">*</span></label><input type="text" ng-model="RegUsername" maxlength="15" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold shadow-sm"></div>
                        <div><label class="block text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-2 pl-1">Password <span class="text-rose-500">*</span></label><input type="password" ng-model="RegPassword" maxlength="20" placeholder="8+ Chars, 1 Upper, 1 Special" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold shadow-sm placeholder-slate-300"></div>
                        <div><label class="block text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-2 pl-1">Confirm Password <span class="text-rose-500">*</span></label><input type="password" ng-model="RegConfirmPassword" maxlength="20" class="w-full px-5 py-4 rounded-2xl bg-white border-2 border-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all font-bold shadow-sm"></div>
                    </div>
                </div>
            </div>

            <div class="mt-12 flex justify-center border-t border-slate-100 pt-10">
                <button ng-click="saveUser()" ng-disabled="!isFormValid()" class="px-14 py-5 rounded-2xl font-black text-white bg-slate-900 hover:bg-indigo-600 disabled:bg-slate-200 disabled:text-slate-400 shadow-xl shadow-slate-900/10 hover:shadow-indigo-500/30 transition-all flex items-center active:scale-[0.98] tracking-widest uppercase">
                    Submit Registration <i class="material-icons ml-3 text-[22px]">arrow_forward</i>
                </button>
            </div>
        </div>
    </div>

    <footer class="absolute bottom-6 w-full text-center z-20"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">© 2026 B-Serve System. Securely Encrypted.</p></footer>
</div>