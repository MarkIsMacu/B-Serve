@{ Layout = "~/Views/Shared/_BSRMSLayout.cshtml"; }

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        body {
            background: white;
        }

        .print-area {
            width: 100% !important;
            padding: 0 !important;
        }
    }

    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }
</style>

<div class="flex h-screen bg-slate-50 font-sans overflow-hidden selection:bg-indigo-500/30 relative">

    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-indigo-400/20 rounded-full mix-blend-multiply filter blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-10%] left-[20%] w-[500px] h-[500px] bg-violet-400/20 rounded-full mix-blend-multiply filter blur-[120px] pointer-events-none"></div>

    <aside class="no-print w-[280px] bg-[#09090b] text-white flex flex-col hidden md:flex z-20 relative border-r border-slate-800">
        <div class="absolute top-[-10%] left-[-10%] w-[300px] h-[300px] bg-indigo-600/30 rounded-full mix-blend-screen filter blur-[80px] pointer-events-none"></div>
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20 mix-blend-overlay pointer-events-none"></div>

        <div class="h-24 flex items-center px-8 border-b border-white/10 relative z-10">
            <div class="h-10 w-10 bg-gradient-to-br from-blue-600 via-indigo-600 to-violet-600 rounded-xl flex items-center justify-center mr-3 shadow-lg shadow-indigo-500/30 ring-2 ring-white/20"><i class="material-icons text-white text-[20px]">holiday_village</i></div>
            <span class="text-xl font-black tracking-widest uppercase">B-SERVE</span>
        </div>

        <div class="px-6 py-8 relative z-10">
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 pl-1">Administration</p>
            <nav class="space-y-2">
                <a href="#" class="flex items-center px-4 py-3 bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 text-white rounded-2xl font-bold transition-all shadow-lg shadow-indigo-500/25"><i class="material-icons mr-3 text-white text-[20px]">dashboard</i> Dashboard</a>
                <a href="#" ng-click="goTo('AdminApproval')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">how_to_reg</i> Approvals</a>
                <a href="#" ng-click="goTo('AdminUsers')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">people</i> Directory</a>
                <a href="#" ng-click="goTo('AdminRequest')" class="flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-white/10 rounded-2xl font-bold transition-all group"><i class="material-icons mr-3 text-slate-400 group-hover:text-indigo-400 text-[20px] transition-colors">assignment</i> Requests</a>
            </nav>
        </div>

        <div class="mt-auto p-6 relative z-10 border-t border-white/10">
            <button ng-click="goTo('LogIn')" class="flex items-center justify-center w-full px-4 py-3 bg-white/5 text-slate-300 hover:text-white hover:bg-rose-500/80 rounded-2xl font-bold transition-all backdrop-blur-sm"><i class="material-icons mr-2 text-[20px]">logout</i> Sign Out</button>
        </div>
    </aside>

    <main class="print-area flex-1 flex flex-col relative animate-slide-up overflow-y-auto z-10">
        <header class="no-print h-24 bg-white/60 backdrop-blur-2xl border-b border-white sticky top-0 z-30 flex items-center justify-between px-10 shadow-[0_4px_30px_rgb(0,0,0,0.03)]">
            <div><h1 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-slate-900 to-slate-700 tracking-tight">System Overview</h1><p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-1">Live Analytics</p></div>
            <div class="flex items-center gap-4">
                <button ng-click="generatePDFReport()" class="flex items-center bg-white border-2 border-slate-100 text-slate-700 text-sm font-black rounded-2xl px-5 py-2.5 hover:border-indigo-500 hover:text-indigo-600 transition-all shadow-sm active:scale-95"><i class="material-icons mr-2 text-[18px]">picture_as_pdf</i> Export PDF</button>
                <div class="h-10 w-10 rounded-2xl bg-gradient-to-br from-indigo-100 to-violet-100 text-indigo-700 flex items-center justify-center font-black border border-indigo-200">A</div>
            </div>
        </header>

        <div class="p-10 flex-1 flex flex-col max-w-7xl mx-auto w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                <div class="bg-white/70 backdrop-blur-2xl rounded-[2.5rem] p-8 border border-white shadow-[0_8px_40px_rgb(0,0,0,0.06)] relative overflow-hidden group hover:shadow-[0_8px_40px_rgb(79,70,229,0.15)] transition-all">
                    <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-emerald-400/20 to-teal-400/20 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700 z-0"></div>
                    <div class="relative z-10">
                        <div class="p-3 bg-emerald-50 text-emerald-600 rounded-2xl w-fit mb-6 border border-emerald-100 shadow-sm"><i class="material-icons text-3xl">verified_user</i></div>
                        <h2 class="text-6xl font-black text-slate-900 tracking-tighter mb-2">{{ getTotalVerifiedResidents() }}</h2>
                        <p class="text-slate-400 font-black text-[11px] uppercase tracking-widest">Total Verified Residents</p>
                    </div>
                </div>

                <div class="bg-white/70 backdrop-blur-2xl rounded-[2.5rem] p-8 border border-white shadow-[0_8px_40px_rgb(0,0,0,0.06)] relative overflow-hidden group hover:shadow-[0_8px_40px_rgb(79,70,229,0.15)] transition-all">
                    <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-indigo-400/20 to-violet-400/20 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700 z-0"></div>
                    <div class="relative z-10">
                        <div class="p-3 bg-indigo-50 text-indigo-600 rounded-2xl w-fit mb-6 border border-indigo-100 shadow-sm"><i class="material-icons text-3xl">folder_shared</i></div>
                        <h2 class="text-6xl font-black text-slate-900 tracking-tighter mb-2">{{ requestArray.length }}</h2>
                        <p class="text-slate-400 font-black text-[11px] uppercase tracking-widest">Total System Requests</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <div class="bg-white/70 backdrop-blur-2xl rounded-[2.5rem] p-8 border border-white shadow-[0_8px_40px_rgb(0,0,0,0.06)]">
                    <h3 class="text-sm font-black text-slate-900 mb-8 uppercase tracking-widest flex items-center"><div class="p-1.5 bg-indigo-50 rounded-lg mr-2"><i class="material-icons text-[18px] text-indigo-600 block">analytics</i></div> Live Analysis</h3>

                    <div class="mb-6">
                        <div class="flex justify-between text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><span>Pending</span><span class="text-slate-900">{{ countRequests('Pending') }}</span></div>
                        <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden shadow-inner"><div class="bg-gradient-to-r from-amber-400 to-orange-500 h-full rounded-full" style="width: {{ (countRequests('Pending') / requestArray.length) * 100 || 0 }}%"></div></div>
                    </div>
                    <div class="mb-6">
                        <div class="flex justify-between text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><span>Processing</span><span class="text-slate-900">{{ countRequests('On-going') }}</span></div>
                        <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden shadow-inner"><div class="bg-gradient-to-r from-blue-500 via-indigo-500 to-violet-600 h-full rounded-full" style="width: {{ (countRequests('On-going') / requestArray.length) * 100 || 0 }}%"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><span>Resolved</span><span class="text-slate-900">{{ countRequests('Resolved') }}</span></div>
                        <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden shadow-inner"><div class="bg-gradient-to-r from-emerald-400 to-teal-500 h-full rounded-full" style="width: {{ (countRequests('Resolved') / requestArray.length) * 100 || 0 }}%"></div></div>
                    </div>
                </div>

                <div class="bg-white/70 backdrop-blur-2xl rounded-[2.5rem] flex flex-col border border-white shadow-[0_8px_40px_rgb(0,0,0,0.06)] overflow-hidden">
                    <div class="p-8 pb-4 border-b border-white/60"><h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center"><div class="p-1.5 bg-indigo-50 rounded-lg mr-2"><i class="material-icons text-[18px] text-indigo-600 block">history</i></div> Recent Activity</h3></div>
                    <div class="overflow-y-auto flex-1 p-2">
                        <table class="min-w-full">
                            <tbody>
                                <tr ng-repeat="req in requestArray | limitTo: -5 track by $index" class="border-b border-slate-100/50 last:border-0 hover:bg-white/50 transition-colors">
                                    <td class="px-6 py-5 text-sm font-bold text-slate-900">{{req.Sender}}</td>
                                    <td class="px-6 py-5 text-[11px] font-black text-slate-400 uppercase tracking-widest">{{req.Type}}</td>
                                    <td class="px-6 py-5 text-right">
                                        <span ng-show="req.Status == 'Pending'" class="px-3 py-1.5 text-[9px] font-black tracking-widest uppercase rounded-lg bg-amber-50 text-amber-600 border border-amber-100">Pending</span>
                                        <span ng-show="req.Status == 'On-going'" class="px-3 py-1.5 text-[9px] font-black tracking-widest uppercase rounded-lg bg-indigo-50 text-indigo-600 border border-indigo-100">Processing</span>
                                        <span ng-show="req.Status == 'Resolved'" class="px-3 py-1.5 text-[9px] font-black tracking-widest uppercase rounded-lg bg-emerald-50 text-emerald-600 border border-emerald-100">Resolved</span>
                                    </td>
                                </tr>
                                <tr ng-show="requestArray.length == 0"><td colspan="3" class="text-center py-10 text-slate-400 text-[10px] font-black uppercase tracking-widest">No activity found</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <footer class="mt-auto pt-6 text-center no-print"><p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">© 2026 B-Serve Admin Command Center.</p></footer>
        </div>
    </main>
</div>