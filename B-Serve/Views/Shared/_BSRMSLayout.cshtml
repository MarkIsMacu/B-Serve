<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>B-Serve | Barangay System</title>

    <style>
        /* Itago ang AngularJS template para hindi mag-flash ng raw {{}} text bago mag-load. */
        [ng\:cloak], [ng-cloak], [data-ng-cloak], [x-ng-cloak], .ng-cloak, .x-ng-cloak {
            display: none !important;
        }

        /* --- GLOBAL SMOOTHNESS STYLES --- */

        /* Fade-in ng buong body kapag nag-load ang page. */
        body {
            animation: pageFadeIn 0.2s ease-out both;
        }
        @@keyframes pageFadeIn {
            from { opacity: 0; transform: translateY(4px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ------------------------------------------------------------------ */
        /* PAGE TRANSITION OVERLAY                                             */
        /* Ito ang nagtatakip ng page bago lumipat para walang white flash.    */
        /* ------------------------------------------------------------------ */
        #bserve-page-overlay {
            position: fixed;
            inset: 0;
            background: #f8fafc;
            z-index: 99999;
            opacity: 1; /* Start fully opaque to hide loading flashes */
            pointer-events: all;
            transition: opacity 0.25s ease;
        }
        /* Kapag nag-load na ang page, itatago na ang overlay */
        #bserve-page-overlay.loaded {
            opacity: 0;
            pointer-events: none;
        }
        /* Kapag paalis na ang page (navigating away), ibabalik ang overlay */
        #bserve-page-overlay.navigating {
            opacity: 1;
            pointer-events: all;
        }

        /* Top progress bar — lumalabas habang nag-loload ang bagong page. */
        #bserve-progress-bar {
            position: fixed;
            top: 0; left: 0;
            height: 3px;
            width: 0%;
            background: linear-gradient(90deg, #6366f1, #8b5cf6, #06b6d4);
            z-index: 100000;
            border-radius: 0 99px 99px 0;
            transition: width 0.4s ease, opacity 0.3s ease;
            opacity: 0;
        }
        #bserve-progress-bar.running {
            opacity: 1;
            width: 80%;
        }
        #bserve-progress-bar.done {
            width: 100%;
            opacity: 0;
            transition: width 0.15s ease, opacity 0.3s ease 0.1s;
        }

        /* Slide-up animation — ginagamit sa mga card at form panels. */
        .animate-slide-up {
            animation: slideUp 0.3s ease-out both;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Smooth transitions para sa lahat ng buttons at links. */
        button, a {
            transition: opacity 0.15s ease, transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        }
        button:active {
            transform: scale(0.97);
        }

        /* Smooth transitions para sa lahat ng input boxes. */
        input, select, textarea {
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        /* Smooth transitions para sa lahat ng table rows. */
        tr {
            transition: background-color 0.15s ease;
        }

        /* Custom scrollbar — payat at maayos ang hitsura. */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <script>
        // I-store ang base URL para walang 404 errors sa routing ng IIS Express.
        window.appBaseUrl = '@Url.Content("~")';

        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: { 50: '#eff6ff', 100: '#dbeafe', 500: '#3b82f6', 600: '#2563eb', 800: '#1e40af', 900: '#1e3a8a' }
                    }
                }
            }
        };

        // ----------------------------------------------------------------
        // PAGE TRANSITION SYSTEM
        // Ito ang nagpapadali ng smooth navigation sa pagitan ng mga pages.
        // ----------------------------------------------------------------
        window.BServeNav = {
            // I-navigate sa bagong page na may fade-out transition bago lumipat.
            go: function (url) {
                var overlay = document.getElementById('bserve-page-overlay');
                var bar     = document.getElementById('bserve-progress-bar');

                // Ipakita ang progress bar
                if (bar) bar.className = 'running';

                // I-fade out ang current page gamit ang overlay
                if (overlay) {
                    overlay.classList.remove('loaded');
                    overlay.classList.add('navigating');
                    // Mag-navigate pagkatapos ng fade (200ms)
                    setTimeout(function () {
                        window.location.href = url;
                    }, 200);
                } else {
                    // Fallback kung hindi pa naka-render ang overlay
                    window.location.href = url;
                }
            }
        };

        // Kapag nag-load na ang bagong page — i-fade in at itago ang overlay.
        window.addEventListener('load', function () {
            var bar = document.getElementById('bserve-progress-bar');
            if (bar) bar.className = 'done';
            
            // Bigyan ng konting delay bago tanggalin ang overlay para maka-render muna si Angular
            setTimeout(function() {
                var overlay = document.getElementById('bserve-page-overlay');
                if (overlay) overlay.classList.add('loaded');
            }, 50);
        });
    </script>
</head>

<body class="bg-gray-50 text-gray-800 font-sans antialiased" ng-app="BSRMSApp" ng-controller="BSRMSController" ng-cloak>

    <!-- Page transition overlay — nagtatakip ng white flash sa pagitan ng mga page loads -->
    <div id="bserve-page-overlay"></div>
    <!-- Top progress bar — nagpapakita ng loading progress -->
    <div id="bserve-progress-bar"></div>

    <div>
        @RenderBody()
    </div>

    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/angular.min.js"></script>
    <script src="~/Scripts/HolyScripts/Module.js"></script>
    <script src="~/Scripts/HolyScripts/Service.js"></script>
    <script src="~/Scripts/HolyScripts/Controller.js"></script>
</body>
</html>